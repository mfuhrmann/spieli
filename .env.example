# Copy this file to .env and adjust for your region.
# docker compose will pick up values from .env automatically.
#
# Find the OSM relation ID for your region at:
#   https://nominatim.openstreetmap.org  (search for your city/Kreis, note the relation ID)
# Find a Geofabrik PBF extract for your region at:
#   https://download.geofabrik.de

# ── Required: region ────────────────────────────────────────────────────────────

# OSM relation ID of the area to display (e.g. 62700 = Landkreis Fulda)
OSM_RELATION_ID=62700

# Geofabrik .osm.pbf download URL covering your region
PBF_URL=https://download.geofabrik.de/europe/germany/hessen-latest.osm.pbf

# ── Optional: UI links ───────────────────────────────────────────────────────────

# Wiki page shown in the "Contribute data" modal (leave empty for the generic OSM playground page)
REGION_PLAYGROUND_WIKI_URL=https://wiki.openstreetmap.org/wiki/Fulda#Spielpl%C3%A4tze

# Community chat link shown in the "Contribute data" modal (leave empty to hide the button)
REGION_CHAT_URL=https://matrix.to/#/#osm-fulda:matrix.org

# ── Optional: map display ────────────────────────────────────────────────────────

# Search radius for nearby POIs shown in the playground detail panel (in metres)
POI_RADIUS_M=5000

# Initial zoom level (the map auto-fits to the region bounding box on load)
MAP_ZOOM=12
MAP_MIN_ZOOM=10

# ── Optional: infrastructure ─────────────────────────────────────────────────────

# Port the app is exposed on the host
APP_PORT=8080

# Database password — change this in production!
POSTGRES_PASSWORD=change-me

# Number of CPU threads for osm2pgsql import
OSM2PGSQL_THREADS=4
